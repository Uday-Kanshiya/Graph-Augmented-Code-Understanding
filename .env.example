# Backend
CONTEXT_ENGINE_DATA_DIR=./data
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
MAX_UPLOAD_MB=200

# Gemini
# Create a key in Google AI Studio and paste it here. Never commit real keys.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional Graphify CLI timeout. Native Graphify support is auto-detected via the `graphify` command.
GRAPHIFY_TIMEOUT_SECONDS=120

# Frontend override lives in frontend/.env.local if you need it:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
